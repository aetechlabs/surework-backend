# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/surework?schema=public"

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRY=7d

# Blockchain
BLOCKCHAIN_NETWORK=polygon-mumbai
RPC_URL=https://rpc-mumbai.maticvigil.com
ESCROW_CONTRACT_ADDRESS=0x...
CHAIN_ID=80001
CONFIRMATION_BLOCKS=3

# USDC Contract Address (Mumbai Testnet)
USDC_CONTRACT_ADDRESS=0x...

# Wallet for Backend Operations (for gas fees if needed)
BACKEND_PRIVATE_KEY=your_private_key_here

# Socket.IO
SOCKET_CORS_ORIGIN=*

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@surework.app

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=

# Admin
ADMIN_EMAIL=admin@surework.app
