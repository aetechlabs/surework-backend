# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/surework?schema=public"

# JWT
JWT_SECRET=dev_secret_key_for_local_development_only_change_in_production_123456789
JWT_EXPIRY=7d

# Blockchain
BLOCKCHAIN_NETWORK=localhost
RPC_URL=http://127.0.0.1:8545
ESCROW_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
CHAIN_ID=31337
CONFIRMATION_BLOCKS=3

# USDC Contract Address (Mumbai Testnet)
USDC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Wallet for Backend Operations (for gas fees if needed)
BACKEND_PRIVATE_KEY=your_private_key_here

# Socket.IO
SOCKET_CORS_ORIGIN=*

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Email (for notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@surework.app

# Push Notifications (Firebase Cloud Messaging)
FCM_SERVER_KEY=

# Admin
ADMIN_EMAIL=admin@surework.app
